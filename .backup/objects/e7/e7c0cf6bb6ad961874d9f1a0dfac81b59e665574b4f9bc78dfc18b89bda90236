// ─── 工具函数 ─────────────────────────

/**
 * 获取某提示词的生效值（用户自定义 > 默认值）
 * @param {string} key - 提示词 key
 * @param {Object} db - 数据库对象
 * @returns {string}
 */
export function getEffectivePrompt(key, db) {
  return (db.customPrompts || {})[key] ?? DEFAULT_PROMPTS[key] ?? '';
}

/**
 * 模板变量替换
 * @param {string} template - 含 {key} 占位符的模板
 * @param {Object} vars - 变量键值对
 * @returns {string}
 */
export function fillTemplate(template, vars) {
  if (!template) return '';
  return template.replace(/\{(\w+)\}/g, (match, key) => {
    return vars[key] !== undefined ? String(vars[key]) : match;
  });
}
