/**
 * 初始化并返回所有 DOM 元素引用
 * @returns {Object<string, HTMLElement>}
 */
export function initDomCache() {
  /** @type {Object<string, HTMLElement>} */
  const dom = {};
  for (const id of IDS) {
    dom[id] = document.getElementById(id);
  }
  dom.screens = document.querySelectorAll('.screen');
  return dom;
}
