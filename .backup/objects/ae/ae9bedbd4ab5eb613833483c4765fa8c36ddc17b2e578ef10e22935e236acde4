/* ========================================
   DataService - 统一数据持久化层（ES Module）
   合并原 engine/db.js 的全部逻辑，消除三角引用断裂。
   所有 IndexedDB 读写集中于此模块管理。
   window.db / window.saveData / window.loadData 通过桥接保留。
   ======================================== */

// ─── Dexie 存储引擎 ─────────────────────────────
// 注意：Dexie 通过 index.html 中的 <script> CDN 加载，全局可用

class DataStorage {
    constructor() {
        this._db = new Dexie('组装姬DB');
        this._db.version(1).stores({
            storage: 'key, value, timestamp'
        });
    }

    async saveData(key, data) {
        try {
            await this._db.storage.put({
                key: key,
                value: JSON.stringify(data),
                timestamp: Date.now()
            });
            return true;
        } catch (error) {
            console.error('[DataStorage] 保存失败:', error);
            return false;
        }
    }

    async getData(key) {
        try {
            const item = await this._db.storage.get(key);
            return item ? JSON.parse(item.value) : null;
        } catch (error) {
            console.error('[DataStorage] 读取失败:', error);
            return null;
        }
    }

    async removeData(key) {
        try {
            await this._db.storage.delete(key);
            return true;
        } catch (error) {
            console.error('[DataStorage] 删除失败:', error);
            return false;
        }
    }

    async clearAll() {
        try {
            await this._db.storage.clear();
            return true;
        } catch (error) {
            console.error('[DataStorage] 清空失败:', error);
            return false;
        }
    }

    async getAllKeys() {
        try {
            const items = await this._db.storage.toArray();
            return items.map(item => item.key);
        } catch (error) {
            console.error('[DataStorage] 获取键名失败:', error);
            return [];
        }
    }
}

// ─── 单例存储实例 ───────────────────────────────
const dataStorage = new DataStorage();

// ─── 内部 db 引用 ───────────────────────────────
// 始终指向全局 window.db，由 engine/db.js 的 var db 声明创建
// 所有非模块脚本直接操作 db 对象属性，原地修改，不替换引用
let _db = (typeof window !== 'undefined' && window.db) || {};

// ─── 私有函数：确保所有字段存在默认值 ──────────
function _ensureDefaults(db) {
    if (!db.characters) db.characters = [];
    if (!db.groups) db.groups = [];
    if (!db.apiSettings) db.apiSettings = {};
    if (!db.apiPresets) db.apiPresets = [];
    if (!db.activeApiPresetId) db.activeApiPresetId = '';

    // 迁移：旧版单配置 → 预设列表
    if (db.apiPresets.length === 0 && db.apiSettings.url) {
        db.apiPresets.push({
            id: 'preset_' + Date.now(),
            name: '默认配置',
            provider: db.apiSettings.provider || 'newapi',
            url: db.apiSettings.url || '',
            key: db.apiSettings.key || '',
            model: db.apiSettings.model || '',
            imgGenUrl: '',
            imgGenKey: ''
        });
        db.activeApiPresetId = db.apiPresets[0].id;
    }

    if (!db.wallpaper || db.wallpaper.includes('postimg.cc') || db.wallpaper.includes('i.postimg')) {
        db.wallpaper = 'assets/wallpaper.jpg';
    }
    if (!db.myStickers) db.myStickers = [];
    if (!db.worldBooks) db.worldBooks = [];
    db.worldBooks.forEach(wb => { if (wb.enabled === undefined) wb.enabled = true; });
    if (!db.fontUrl) db.fontUrl = '';
    if (!db.customIcons) db.customIcons = {};
    if (!db.imgGenSettings) db.imgGenSettings = {};
    if (!db.imgGenSettings.url) db.imgGenSettings.url = 'https://image.pollinations.ai/prompt/';
    if (!db.imgGenSettings.key) db.imgGenSettings.key = '';
    if (!db.imgGenSettings.model) db.imgGenSettings.model = '';

    if (!db.imgGenSettings.url && db.apiPresets.length > 0) {
        const first = db.apiPresets.find(p => p.imgGenUrl);
        if (first) {
            db.imgGenSettings.url = first.imgGenUrl;
            db.imgGenSettings.key = first.imgGenKey || '';
        }
    }

    if (db.money === undefined) db.money = 1000;
    if (!db.ownedItems) db.ownedItems = [];
    if (!db.albumPhotos) db.albumPhotos = [];
    if (db.albumPhotos.length === 0) {
        db.albumPhotos.push({
            id: 'cover_' + Date.now(),
            url: 'assets/album_cover.jpg',
            name: '默认封面',
            isCover: true,
            timestamp: Date.now()
        });
    }

    // 激活世界
    if (db._currentScreen === undefined) db._currentScreen = 'home-screen';
    if (db._currentChatId === undefined) db._currentChatId = '';
    if (db._currentChatType === undefined) db._currentChatType = '';
    if (db.activeWorldEnabled === undefined) db.activeWorldEnabled = false;
    if (db.activeWorldInterval === undefined) db.activeWorldInterval = 5;
    if (!db.activeWorldScope) db.activeWorldScope = 'both';

    if (!db.ttsConfig) db.ttsConfig = { engine: 'local', sogouSpeaker: 1, sogouSpeed: 3 };
    if (!db.customPrompts) db.customPrompts = {};

    // ★ 全局个人资料（"我的资料"）
    if (!db.myProfile) db.myProfile = {};
    if (!db.myProfile.name) db.myProfile.name = '我';
    if (!db.myProfile.persona) db.myProfile.persona = '';
    if (!db.myProfile.avatar) db.myProfile.avatar = 'assets/icons/default-avatar.png';

    (db.characters || []).forEach(c => {
        if (c.isPinned === undefined) c.isPinned = false;
        if (c.status === undefined) c.status = '在线';
        if (!c.worldBookIds) c.worldBookIds = [];
        if (c.customBubbleCss === undefined) c.customBubbleCss = '';
        if (c.useCustomBubbleCss === undefined) c.useCustomBubbleCss = false;
        if (c.memorySummary === undefined) c.memorySummary = '';
        if (!c.keyEvents) c.keyEvents = [];
        if (c.summaryIndex === undefined) c.summaryIndex = 0;
        if (c.aiImgGen === undefined) c.aiImgGen = false;
        if (!c.ttsConfig) c.ttsConfig = { engine: 'global', sogouSpeaker: 1, sogouSpeed: 3 };
        if (!c.builtinWorldBooks) c.builtinWorldBooks = [];
        if (c.scenario === undefined) c.scenario = '';
        if (c.systemPrompt === undefined) c.systemPrompt = '';
        if (c.mesExample === undefined) c.mesExample = '';
        // ★ 态度字段（侧边栏编辑）
        if (c.attitude === undefined) c.attitude = '';
        // ★ "我"的信息回退到全局 myProfile
        if (!c.myName) c.myName = db.myProfile?.name || '我';
        if (!c.myPersona) c.myPersona = db.myProfile?.persona || '';
        if (!c.myAvatar) c.myAvatar = db.myProfile?.avatar || 'assets/icons/default-avatar.png';
    });

    (db.groups || []).forEach(g => {
        if (g.isPinned === undefined) g.isPinned = false;
        if (!g.worldBookIds) g.worldBookIds = [];
        if (g.customBubbleCss === undefined) g.customBubbleCss = '';
        if (g.useCustomBubbleCss === undefined) g.useCustomBubbleCss = false;
        if (g.memorySummary === undefined) g.memorySummary = '';
        if (!g.keyEvents) g.keyEvents = [];
        if (g.summaryIndex === undefined) g.summaryIndex = 0;
        if (!g.builtinWorldBooks) g.builtinWorldBooks = [];
        if (g.scenario === undefined) g.scenario = '';
        if (g.systemPrompt === undefined) g.systemPrompt = '';
        if (!g.ttsConfig) g.ttsConfig = { engine: 'global', sogouSpeaker: 1, sogouSpeed: 3 };
        if (g.members) g.members.forEach(m => {
            if (!m.builtinWorldBooks) m.builtinWorldBooks = [];
            if (m.systemPrompt === undefined) m.systemPrompt = '';
        });
    });
}

// ─── 公开 API ────────────────────────────────────

/**
 * 加载数据（初始化入口，由 app.js 调用）
 * 从 IndexedDB 读取，写入全局 db 对象（原地修改，不替换引用）
 */
export async function loadData() {
    // 兼容旧版 localStorage 迁移
    const oldData = localStorage.getItem('gemini-chat-app-db');
    let data = await dataStorage.getData('组装姬');
    if (oldData) {
        await dataStorage.saveData('组装姬', JSON.parse(oldData));
        data = await dataStorage.getData('组装姬');
        localStorage.removeItem('gemini-chat-app-db');
    }

    // 获取全局 db 对象（由 engine/db.js 的 var db 声明）
    const g = (typeof window !== 'undefined' && window.db) || {};
    _db = g;

    if (data) {
        // 原地复制数据，不替换引用 —— 避免与非模块脚本的 db 变量断开
        Object.assign(_db, data);
    }

    // 确保默认值
    _ensureDefaults(_db);

    // 同步回 window（确保全局变量可见）
    if (typeof window !== 'undefined') window.db = _db;

    // ★ 覆盖全局 saveData / loadData —— 非模块脚本（engine/*、modules/*）的后续调用全部委托到 dataService
    // 注意：engine/db.js 中 var saveData/loadData 的初始赋值可能被 hoisting 提升，
    // 但 window.saveData / window.loadData 的覆盖是实时的，
    // 所有非模块脚本通过 typeof saveData !== 'undefined' 检查后调用的其实是 window.saveData
    if (typeof window !== 'undefined') {
        window.saveData = saveData;
        window.loadData = loadData;
    }

    console.log('[DataService] loadData 完成 - characters:', (_db.characters || []).length,
        'groups:', (_db.groups || []).length, 'worldBooks:', (_db.worldBooks || []).length);
    return _db;
}

/**
 * 保存数据到 IndexedDB
 * @param {Object} [newDb] - 可选，要合并的数据（原地合并到 _db）
 */
export async function saveData(newDb) {
    if (newDb) {
        Object.assign(_db, newDb);
    }

    // 确保 window 同步
    if (typeof window !== 'undefined') window.db = _db;

    await dataStorage.saveData('组装姬', _db);
}

/** 获取当前 db 引用 */
export function getDb() {
    return _db;
}

// ─── 便捷访问方法 ─────────────────────────────────

export function getCharacter(id) {
    return (_db.characters || []).find(c => c.id === id);
}

export function getGroup(id) {
    return (_db.groups || []).find(g => g.id === id);
}

export async function updateCharacter(id, changes) {
    const char = getCharacter(id);
    if (char) {
        Object.assign(char, changes);
        await saveData();
    }
}

export function getActiveApi() {
    if (_db.apiPresets && _db.apiPresets.length > 0 && _db.activeApiPresetId) {
        return _db.apiPresets.find(p => p.id === _db.activeApiPresetId);
    }
    return _db.apiSettings || {};
}

// ─── 全局桥接：供非模块 script 使用 ──────────────
// engine/db.js 中的 var saveData / var loadData 通过此桥接委托
if (typeof window !== 'undefined') {
    window.__dataService = {
        saveData: saveData,
        loadData: loadData,
        getDb: getDb,
        getCharacter: getCharacter,
        getGroup: getGroup,
        updateCharacter: updateCharacter,
        getActiveApi: getActiveApi
    };
}
